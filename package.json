{
  "name": "jobsieve",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev:api": "pnpm --filter jobsieve-api dev",
    "dev:ui": "pnpm --filter jobsieve-frontend dev",

    "build:api": "pnpm --filter jobsieve-api build",
    "build:ui": "pnpm --filter jobsieve-frontend build",
    "build": "pnpm run build:ui && pnpm run build:api",

    "start": "pnpm --filter jobsieve-api start",

    "test": "pnpm --filter jobsieve-api test",
    "test:watch": "pnpm --filter jobsieve-api test:watch",
    "test:cov": "pnpm --filter jobsieve-api test:cov",
    "test:e2e": "pnpm --filter jobsieve-api test:e2e",

    "lint": "pnpm --filter jobsieve-api lint",
    "format": "pnpm --filter jobsieve-api format",
    "ingest": "pnpm --filter jobsieve-api ingest",
    "dedup": "pnpm --filter jobsieve-api dedup",
    "score-audit": "pnpm --filter jobsieve-api score-audit"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "@nestjs/core", "unrs-resolver", "esbuild"]
  }
}
