# ─── Database ────────────────────────────────────────────────────────────────
# Path to the SQLite file, relative to api/ (where NestJS runs). The directory must exist before first run.
DATABASE_PATH=../data/jobsieve.sqlite

# ─── Cron schedule ───────────────────────────────────────────────────────────
# Standard cron expression. Default: every 4 hours.
CRON_SCHEDULE=0 */4 * * *

# ─── API server ──────────────────────────────────────────────────────────────
API_PORT=3000

# ─── Source adapters ─────────────────────────────────────────────────────────
# web3.career: get a free token at https://web3.career/api-docs
WEB3CAREER_TOKEN=your_web3career_token_here

# ─── Fit scoring ─────────────────────────────────────────────────────────────
# Fallback minimum fit score when the relevance profile leaves minFitScore unset.
# Jobs scoring below this are stored but hidden from the default view.
MIN_FIT_SCORE=4

# RETIRED: scoring is now driven by the editable relevance profile (Settings page)
# + the taxonomy in api/src/scoring/taxonomy.ts. STACK_KEYWORDS / SENIORITY_KEYWORDS
# are no longer read; leave unset. Kept optional only so old .env files still load.

# ─── Notion sync (optional) ──────────────────────────────────────────────────
# Leave both blank to disable Notion sync entirely. If set, both must be present.
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Column names in your Notion database. Defaults match the names below.
# Override if your database uses different column names.
NOTION_COL_TITLE=Name
NOTION_COL_COMPANY=Company
NOTION_COL_URL=URL
NOTION_COL_STATUS=Status
NOTION_COL_FIT_SCORE=FitScore
NOTION_COL_SOURCE=Source
NOTION_COL_POSTED_AT=PostedAt
NOTION_COL_TAGS=Tags

# ─── Volume control ──────────────────────────────────────────────────────────
# Set to "true" to filter high-volume ATS/JSON sources by job title.
# Only titles matching the built-in regex (backend|engineer|developer|...) pass.
# Niche web3 RSS feeds are never filtered. Leave unset to receive all titles.
TITLE_ALLOWLIST_ENABLED=

# ─── Production note ─────────────────────────────────────────────────────────
# In production, source all secrets from a secrets manager
# (AWS Secrets Manager, HashiCorp Vault, etc.). Never commit a real .env file.
