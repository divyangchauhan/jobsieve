# ─── Database ────────────────────────────────────────────────────────────────
# Path to the SQLite file, relative to api/ (where NestJS runs). The directory must exist before first run.
DATABASE_PATH=../data/jobsieve.sqlite

# ─── Cron schedule ───────────────────────────────────────────────────────────
# Standard cron expression. Default: every 4 hours.
CRON_SCHEDULE=0 */4 * * *

# ─── API server ──────────────────────────────────────────────────────────────
API_PORT=3000

# ─── Source adapters ─────────────────────────────────────────────────────────
# web3.career: get a free token at https://web3.career/api-docs
WEB3CAREER_TOKEN=your_web3career_token_here

# ─── Fit scoring ─────────────────────────────────────────────────────────────
# Jobs with fit_score below this are stored but hidden from the default view.
MIN_FIT_SCORE=4

# Comma-separated keywords matched against title + description (case-insensitive).
# Each match adds +2 to fit_score.
STACK_KEYWORDS=typescript,nestjs,node,nodejs,python,aws,kafka,web3,solidity,graphql,postgres,redis

# Comma-separated seniority keywords matched against title (case-insensitive).
# Each match adds +3 to fit_score.
SENIORITY_KEYWORDS=senior,lead,staff,principal,architect

# ─── Notion sync (optional) ──────────────────────────────────────────────────
# Leave both blank to disable Notion sync entirely. If set, both must be present.
NOTION_TOKEN=
NOTION_DATABASE_ID=

# ─── Production note ─────────────────────────────────────────────────────────
# In production, source all secrets from a secrets manager
# (AWS Secrets Manager, HashiCorp Vault, etc.). Never commit a real .env file.
